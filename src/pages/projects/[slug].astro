---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Button from "../../components/ui/Button.astro";
import { Icon } from "astro-icon/components";
import { projects, type Project } from "../../data/projects";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

// Mise en forme légère : **gras** et `code`
const formatText = (text: string) =>
  text
    .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
    .replace(
      /`([^`]+)`/g,
      '<code class="px-1.5 py-0.5 rounded bg-ink-100 dark:bg-night-border text-accent-700 dark:text-accent-200 text-sm font-mono">$1</code>',
    );
---

<Layout
  title={`${project.title} - Baptiste TABAR LABONNE`}
  description={project.description}
>
  <Header />
  <main id="main" class="min-h-[100dvh]">
    <!-- En-tête de l'étude de cas -->
    <section class="px-4 md:px-8 pt-36 pb-12">
      <div class="max-w-3xl mx-auto">
        <!-- Fil d'Ariane -->
        <nav class="mb-8 reveal">
          <a
            href={`/#${project.slug}`}
            class="inline-flex items-center gap-1.5 font-mono text-sm text-ink-500 dark:text-ink-300 hover:text-accent-600 dark:hover:text-accent-300 transition-colors"
          >
            <Icon name="heroicons:arrow-left" class="w-3.5 h-3.5" aria-hidden="true" />
            Projets
          </a>
        </nav>

        <h1 class="font-display text-4xl md:text-6xl leading-[1.1] text-ink-900 dark:text-ink-50 mb-6 reveal">
          {project.title}
        </h1>

        <p class="text-lg text-ink-500 dark:text-ink-300 leading-relaxed mb-6 reveal">
          {project.description}
        </p>

        <!-- Stack -->
        <div class="flex flex-wrap gap-2 mb-8 reveal">
          {project.technologies.map((tech) => (
            <span class="font-mono text-xs px-2.5 py-1 rounded-md bg-ink-50 text-ink-600 border border-ink-200 dark:bg-night-card dark:text-ink-200 dark:border-night-border">
              {tech}
            </span>
          ))}
        </div>

        <!-- Actions -->
        <div class="flex flex-wrap gap-3 reveal">
          {project.demo && (
            <Button href={project.demo} variant="primary" size="sm">
              <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 mr-2" aria-hidden="true" />
              {project.demoLabel || 'Voir la démo'}
            </Button>
          )}
          {project.github && (
            <Button href={project.github} variant="outline" size="sm">
              <Icon name="simple-icons:github" class="w-4 h-4 mr-2" aria-hidden="true" />
              Code source
            </Button>
          )}
        </div>

        {project.image && (
          <div class="mt-12 reveal card p-0 overflow-hidden">
            <img
              src={project.image}
              alt={`Aperçu du projet ${project.title}`}
              class={project.image.includes('logo') ? 'w-full h-48 object-contain bg-white p-6' : 'w-full object-cover'}
              loading="eager"
            />
          </div>
        )}
      </div>
    </section>

    <!-- Présentation Canva pour Beroli -->
    {project.slug === 'beroli' && (
      <section class="px-4 md:px-8 py-12">
        <div class="max-w-content mx-auto">
          <h2 class="font-display text-3xl text-ink-900 dark:text-ink-50 mb-6 reveal">Présentation complète</h2>
          <div class="card p-3 reveal">
            <iframe
              src="https://www.canva.com/design/DAF-QIOEFEw/H_RNdqkVg2smDcXOgbXX9w/view?embed"
              class="w-full h-[600px] md:h-[800px] rounded-xl border-0"
              allowfullscreen="allowfullscreen"
              allow="fullscreen"
              title="Présentation Beroli - Application mobile"
            ></iframe>
          </div>
        </div>
      </section>
    )}

    <!-- Contenu détaillé -->
    {project.detailedContent && (
      <section class="px-4 md:px-8 py-12">
        <div class="max-w-3xl mx-auto space-y-16">
          <!-- Contexte -->
          {project.detailedContent.introduction && (
            <div class="reveal">
              <h2 class="font-display text-2xl md:text-3xl text-ink-900 dark:text-ink-50 mb-6">Contexte</h2>
              {project.detailedContent.introduction.split('\n\n').map(paragraph => (
                <p class="text-ink-600 dark:text-ink-200 leading-relaxed mb-4 last:mb-0" set:html={formatText(paragraph)} />
              ))}
            </div>
          )}

          <!-- Fonctionnalités -->
          {project.detailedContent.features && (
            <div class="reveal">
              <h2 class="font-display text-2xl md:text-3xl text-ink-900 dark:text-ink-50 mb-6">Ce que fait l'application</h2>
              <ul class="space-y-2.5">
                {project.detailedContent.features.map((feature) => (
                  feature.startsWith('  •') ? (
                    <li class="ml-8 text-ink-500 dark:text-ink-300 text-sm leading-relaxed">
                      {feature.replace('  • ', '')}
                    </li>
                  ) : (
                    <li class="flex items-start gap-3 text-ink-600 dark:text-ink-200 leading-relaxed">
                      <Icon name="heroicons:check" class="w-4 h-4 text-accent-500 dark:text-accent-300 flex-shrink-0 mt-1.5" aria-hidden="true" />
                      <span>{feature}</span>
                    </li>
                  )
                ))}
              </ul>
            </div>
          )}

          <!-- Décisions techniques -->
          {project.detailedContent.technical && (
            <div class="reveal">
              <h2 class="font-display text-2xl md:text-3xl text-ink-900 dark:text-ink-50 mb-6">Décisions techniques</h2>
              <div class="space-y-4">
                {project.detailedContent.technical.map((section) => (
                  <details class="card p-0 overflow-hidden group" open>
                    <summary class="cursor-pointer px-6 py-4 font-semibold text-ink-900 dark:text-ink-50 flex items-center justify-between hover:bg-ink-50 dark:hover:bg-night-bg transition-colors">
                      {section.title}
                      <Icon name="heroicons:chevron-down" class="w-4 h-4 text-ink-500 transition-transform group-open:rotate-180" aria-hidden="true" />
                    </summary>
                    <ul class="px-6 pb-5 pt-1 space-y-2.5">
                      {section.items.map((item) => (
                        <li class="flex items-start gap-3 text-sm text-ink-600 dark:text-ink-200 leading-relaxed">
                          <span class="w-1 h-1 rounded-full bg-ink-300 dark:bg-ink-500 flex-shrink-0 mt-2" aria-hidden="true"></span>
                          <div>
                            {item.split('\n').map((paragraph, i) => (
                              <Fragment>
                                {i > 0 && <br />}
                                <span set:html={formatText(paragraph)} />
                              </Fragment>
                            ))}
                          </div>
                        </li>
                      ))}
                    </ul>
                  </details>
                ))}
              </div>
            </div>
          )}

          <!-- Workflow -->
          {project.detailedContent.workflow && (
            <div class="reveal">
              <h2 class="font-display text-2xl md:text-3xl text-ink-900 dark:text-ink-50 mb-6">Workflow</h2>
              {project.detailedContent.workflow.split('\n\n').map(paragraph => (
                <p class="text-ink-600 dark:text-ink-200 leading-relaxed mb-4 last:mb-0 whitespace-pre-line" set:html={formatText(paragraph)} />
              ))}
            </div>
          )}

          <!-- Monitoring -->
          {project.detailedContent.monitoring && (
            <div class="reveal">
              <h2 class="font-display text-2xl md:text-3xl text-ink-900 dark:text-ink-50 mb-6">Monitoring</h2>
              {project.detailedContent.monitoring.split('\n\n').map(paragraph => (
                <p class="text-ink-600 dark:text-ink-200 leading-relaxed mb-4 last:mb-0 whitespace-pre-line" set:html={formatText(paragraph)} />
              ))}
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Captures d'écran -->
    {project.screenshots && project.screenshots.length > 0 && (
      <section class="px-4 md:px-8 py-12">
        <div class="max-w-content mx-auto">
          <h2 class="font-display text-3xl text-ink-900 dark:text-ink-50 mb-8 reveal">Captures d'écran</h2>
          <div class="grid md:grid-cols-2 gap-5">
            {(() => {
              // Regrouper les versions light/dark d'une même capture
              const screenshotGroups = new Map();
              project.screenshots.forEach(screenshot => {
                if (!screenshotGroups.has(screenshot.name)) {
                  screenshotGroups.set(screenshot.name, []);
                }
                screenshotGroups.get(screenshot.name).push(screenshot);
              });

              const uniqueScreenshots: {
                name: string;
                path?: string;
                darkPath?: string;
                lightPath?: string;
              }[] = [];
              screenshotGroups.forEach((group, name) => {
                if (group.length === 2) {
                  const darkImg = group.find((s: { path: string }) => s.path.includes('black') || s.path.includes('dark'));
                  const lightImg = group.find((s: { path: string }) => s.path.includes('white') || s.path.includes('light'));
                  uniqueScreenshots.push({ name, darkPath: darkImg?.path, lightPath: lightImg?.path });
                } else {
                  uniqueScreenshots.push({ name, path: group[0].path });
                }
              });

              return uniqueScreenshots.map((screenshot) => (
                <figure class="reveal card p-0 overflow-hidden">
                  <img
                    src={screenshot.path || screenshot.darkPath}
                    data-image-dark={screenshot.darkPath}
                    data-image-light={screenshot.lightPath}
                    alt={screenshot.name}
                    class="w-full h-64 object-cover object-top border-b border-ink-200 dark:border-night-border"
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption class="px-5 py-3 text-sm text-ink-500 dark:text-ink-300">
                    {screenshot.name}
                  </figcaption>
                </figure>
              ));
            })()}
          </div>
        </div>
      </section>
    )}

    <!-- Retour -->
    <section class="px-4 md:px-8 py-12">
      <div class="max-w-3xl mx-auto reveal">
        <Button href={`/#${project.slug}`} variant="outline" size="sm">
          <Icon name="heroicons:arrow-left" class="w-4 h-4 mr-2" aria-hidden="true" />
          Retour aux projets
        </Button>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  // Bascule light/dark des captures qui ont deux versions
  const updateScreenshotImages = () => {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll('img[data-image-dark][data-image-light]').forEach(img => {
      const imageElement = img as HTMLImageElement;
      const darkImage = imageElement.getAttribute('data-image-dark');
      const lightImage = imageElement.getAttribute('data-image-light');
      if (darkImage && lightImage) {
        imageElement.src = isDark ? darkImage : lightImage;
      }
    });
  };

  updateScreenshotImages();

  const observer = new MutationObserver(updateScreenshotImages);
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class']
  });
</script>

---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Section from "../../components/ui/Section.astro";
import Button from "../../components/ui/Button.astro";
import { Icon } from "astro-icon/components";
import { projects, type Project } from "../../data/projects";
import { extractTechnologiesFromText, getTechIcon, iconExists } from "../../data/techIcons"

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<Layout
  title={`${project.title} - Baptiste TABAR LABONNE`}
  description={project.description}
>
  <Header />
  <main class="min-h-screen">
    <!-- Hero Section -->
    <Section className="bg-dark-800/30 pt-32">
      <div class="max-w-4xl mx-auto">
        <!-- Breadcrumb -->
        <nav class="mb-8 reveal">
          <ol class="flex items-center space-x-2 text-sm text-dark-400">
            <li>
              <a href={`/#${project.slug}`} class="hover:text-primary-400 transition-colors">
                Projets
              </a>
            </li>
            <li>
              <Icon name="heroicons:chevron-right" class="w-4 h-4" aria-hidden="true" />
            </li>
            <li class="text-dark-200">{project.title}</li>
          </ol>
        </nav>

        <!-- Title -->
        <h1 class="text-4xl md:text-5xl font-bold mb-6 gradient-text reveal">
          {project.title}
        </h1>

        <!-- Description -->
        <p class="text-lg text-dark-300 mb-8 reveal">
          {project.description}
        </p>

        <!-- Actions -->
        <div class="flex flex-wrap justify-center md:justify-start gap-4 mb-12 reveal">
          {project.demo && (
            <Button href={project.demo} variant="primary">
              <Icon name="heroicons:arrow-top-right-on-square" class="w-5 h-5 mr-2" aria-hidden="true" />
              {project.demoLabel || 'Voir la démo'}
            </Button>
          )}
          {project.github && (
            <Button href={project.github} variant="outline">
              <Icon name="simple-icons:github" class="w-5 h-5 mr-2" aria-hidden="true" />
              Code source
            </Button>
          )}
        </div>

        <!-- Main Image -->
        <div class="rounded-2xl overflow-hidden shadow-lg mb-12 reveal max-w-2xl mx-auto">
          <img 
            src={project.image} 
            alt={project.title}
            class={project.image.includes('logo') ? 'w-full h-48 object-contain bg-white p-6' : 'w-full h-64 object-cover'}
            loading="eager"
          />
        </div>

        <!-- Technologies -->
        <!-- <div class="mb-12 reveal">
          <h2 class="text-2xl font-bold text-dark-100 mb-4">Technologies utilisées</h2>
          <div class="flex flex-wrap gap-3">
            {project.technologies.map((tech) => (
              <span class="px-4 py-2 rounded-xl glass text-primary-400 border border-dark-700 hover:border-primary-500 transition-colors">
                {tech}
              </span>
            ))}
          </div>
        </div> -->
      </div>
    </Section>

    <!-- Canva Presentation for Beroli -->
    {project.slug === 'beroli' && (
      <Section className="bg-dark-800/30">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-dark-100 mb-8 text-center reveal">Présentation complète de l'application</h2>
          <div class="glass rounded-2xl p-4 reveal">
            <iframe
              src="https://www.canva.com/design/DAF-QIOEFEw/H_RNdqkVg2smDcXOgbXX9w/view?embed"
              class="w-full h-[600px] md:h-[800px] rounded-xl border-0"
              allowfullscreen="allowfullscreen"
              allow="fullscreen"
              title="Présentation Beroli - Application mobile"
            ></iframe>
          </div>
        </div>
      </Section>
    )}

    <!-- Detailed Content -->
    {project.detailedContent && (
      <Section>
        <div class="max-w-4xl mx-auto">
          <!-- Introduction -->
          {project.detailedContent.introduction && (
            <div class="mb-12 reveal">
              <h2 class="text-3xl font-bold text-dark-100 mb-6">À propos du projet</h2>
              <div class="glass rounded-2xl p-8">
                {project.detailedContent.introduction.split('\n\n').map(paragraph => (
                  <p class="text-dark-300 text-lg leading-relaxed mb-4 last:mb-0" set:html={paragraph.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/`([^`]+)`/g, '<code class="px-2 py-1 rounded bg-dark-800 text-primary-400 text-sm font-mono">$1</code>')}>
                  </p>
                ))}
              </div>
            </div>
          )}

          <!-- Features -->
          {project.detailedContent.features && (
            <div class="mb-12 reveal">
              <h2 class="text-3xl font-bold text-dark-100 mb-6">Fonctionnalités principales</h2>
              <div class="glass rounded-2xl p-8">
                <ul class="space-y-3">
                  {project.detailedContent.features.map((feature) => (
                    <li class="flex items-start text-dark-300 text-lg">
                      {feature.startsWith('  •') ? (
                        <span class="ml-8">{feature}</span>
                      ) : (
                        <>
                          <Icon name="heroicons:check-badge" class="w-6 h-6 text-primary-500 mr-3 flex-shrink-0 mt-1" aria-hidden="true" />
                          <span>{feature}</span>
                        </>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

          <!-- Technical Details -->
          {project.detailedContent.technical && (
            <div class="mb-12 reveal">
              <h2 class="text-3xl font-bold text-dark-100 mb-6">Détails techniques</h2>
              <div class="space-y-6">
                {project.detailedContent.technical.map((section) => {
                  const technologies = extractTechnologiesFromText(section.items.join(' ')).filter(tech => getTechIcon(tech));
                  return (
                    <div class="glass rounded-2xl p-8">
                      <div class="flex items-center gap-3 mb-4">
                        <h3 class="text-xl font-bold text-primary-400">{section.title}</h3>
                        {technologies.length > 0 && (
                          <div class="flex items-center gap-2 ml-2">
                            {technologies.map((tech) => {
                              const iconPath = getTechIcon(tech);
                              return iconPath && iconExists(iconPath) ? (
                                <img 
                                  src={iconPath}
                                  alt={tech}
                                  title={tech}
                                  class="w-5 h-5 inline-block"
                                />
                              ) : null;
                            })}
                          </div>
                        )}
                      </div>
                      <ul class="space-y-3">
                        {section.items.map((item) => (
                          <li class="flex items-start text-dark-300">
                            <Icon name="heroicons:arrow-right" class="w-5 h-5 text-primary-500 mr-3 flex-shrink-0 mt-1" aria-hidden="true" />
                            <div>
                              {item.split('\n').map((paragraph, i) => (
                                <Fragment>
                                  {i > 0 && <><br /></>}
                                  <span set:html={paragraph.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/`([^`]+)`/g, '<code class="px-2 py-1 rounded bg-dark-800 text-primary-400 text-sm font-mono">$1</code>')} />
                                </Fragment>
                              ))}
                            </div>
                          </li>
                        ))}
                      </ul>
                    </div>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      </Section>
    )}

    <!-- Screenshots Gallery -->
    {project.screenshots && project.screenshots.length > 0 && (
      <Section className="bg-dark-800/30">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-dark-100 mb-8 text-center reveal">Galerie d'images</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {(() => {
              // Grouper les screenshots par nom pour gérer les versions light/dark
              const screenshotGroups = new Map();
              project.screenshots.forEach(screenshot => {
                if (!screenshotGroups.has(screenshot.name)) {
                  screenshotGroups.set(screenshot.name, []);
                }
                screenshotGroups.get(screenshot.name).push(screenshot);
              });

                const uniqueScreenshots: {
                name: string;
                path?: string;
                darkPath?: string;
                lightPath?: string;
                }[] = [];
              screenshotGroups.forEach((group, name) => {
                if (group.length === 2) {
                  // Deux versions : light et dark
                  const darkImg = group.find((s: { path: string }) => s.path.includes('black') || s.path.includes('dark'));
                  const lightImg = group.find((s: { path: string }) => s.path.includes('white') || s.path.includes('light'));
                  uniqueScreenshots.push({
                    name,
                    darkPath: darkImg?.path,
                    lightPath: lightImg?.path
                  });
                } else {
                  // Une seule version
                  uniqueScreenshots.push({
                    name,
                    path: group[0].path
                  });
                }
              });

              return uniqueScreenshots.map((screenshot, index) => (
                <div class="reveal glass rounded-2xl overflow-hidden group cursor-pointer" style={`animation-delay: ${index * 0.1}s`}>
                  <div class="relative overflow-hidden">
                    <img 
                      src={screenshot.path || screenshot.darkPath}
                      data-image-dark={screenshot.darkPath}
                      data-image-light={screenshot.lightPath}
                      alt={screenshot.name}
                      class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-dark-900 via-transparent to-transparent opacity-60"></div>
                    <div class="absolute bottom-0 left-0 right-0 p-4">
                      <p class="text-white font-semibold">{screenshot.name}</p>
                    </div>
                  </div>
                </div>
              ));
            })()}
          </div>
        </div>
      </Section>
    )}

    <!-- Back to Projects -->
    <Section>
      <div class="text-center reveal">
        <Button href={`/#${project.slug}`} variant="outline">
          <Icon name="heroicons:arrow-left" class="w-5 h-5 mr-2" aria-hidden="true" />
          Retour aux projets
        </Button>
      </div>
    </Section>
  </main>
  <Footer />
</Layout>

<script>
  // Fonction pour mettre à jour les images des screenshots selon le thème
  const updateScreenshotImages = () => {
    const isDark = document.documentElement.classList.contains('dark');
    const screenshotImages = document.querySelectorAll('img[data-image-dark][data-image-light]');
    
    screenshotImages.forEach(img => {
      const imageElement = img as HTMLImageElement;
      const darkImage = imageElement.getAttribute('data-image-dark');
      const lightImage = imageElement.getAttribute('data-image-light');
      
      if (darkImage && lightImage) {
        imageElement.src = isDark ? darkImage : lightImage;
      }
    });
  };

  // Mettre à jour les images au chargement initial
  updateScreenshotImages();

  // Écouter les changements de thème
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
        updateScreenshotImages();
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class']
  });
</script>

<style>
  /* Animation pour les éléments reveal */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

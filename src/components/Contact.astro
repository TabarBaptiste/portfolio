---
import Section from "./ui/Section.astro";
import { Icon } from "astro-icon/components";

const email = "tabarbaptiste@gmail.com";

const links = [
    {
        name: "LinkedIn",
        value: "baptiste-tabar-labonne",
        url: "https://www.linkedin.com/in/baptiste-tabar-labonne/",
        icon: "simple-icons:linkedin",
    },
    {
        name: "GitHub",
        value: "TabarBaptiste",
        url: "https://github.com/TabarBaptiste",
        icon: "simple-icons:github",
    },
    {
        name: "Téléphone",
        value: "07 63 48 62 78",
        url: "tel:+33763486278",
        icon: "heroicons:phone",
    },
];
---

<Section id="contact" title="Contact">
    <div class="max-w-3xl reveal">
        <p class="text-xl md:text-2xl text-ink-700 dark:text-ink-100 leading-relaxed mb-2">
            Un poste, un projet, une question ?
        </p>
        <p class="text-ink-500 dark:text-ink-300 mb-8">
            Je réponds vite. Disponible dès octobre 2026, en Île-de-France
            comme en Martinique, sur site ou en télétravail.
        </p>

        <!-- Email en évidence -->
        <a
            href={`mailto:${email}`}
            class="group inline-flex items-center gap-3 font-mono text-xl md:text-3xl text-ink-900 dark:text-ink-50 hover:text-accent-600 dark:hover:text-accent-300 transition-colors mb-10 break-all"
        >
            {email}
            <Icon
                name="heroicons:arrow-up-right"
                class="w-5 h-5 md:w-6 md:h-6 flex-shrink-0 text-accent-600 dark:text-accent-300 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                aria-hidden="true"
            />
        </a>

        <!-- Autres canaux -->
        <div class="flex flex-wrap gap-3">
            {links.map((link) => (
                <a
                    href={link.url}
                    target={link.url.startsWith("http") ? "_blank" : undefined}
                    rel={link.url.startsWith("http") ? "noopener noreferrer" : undefined}
                    class="card px-4 py-3 flex items-center gap-3 hover:border-ink-300 dark:hover:border-ink-600 transition-colors group"
                >
                    <Icon
                        name={link.icon}
                        class="w-4 h-4 text-ink-400 dark:text-ink-300 group-hover:text-accent-600 dark:group-hover:text-accent-300 transition-colors"
                        aria-hidden="true"
                    />
                    <span class="text-sm text-ink-700 dark:text-ink-100">{link.value}</span>
                </a>
            ))}
        </div>
    </div>
</Section>

---
import { Icon } from "astro-icon/components";

// Dès le 01/10/2026, on affiche "immédiatement" à la place de "octobre 2026"
const availabilityDate = new Date('2026-10-01');
const today = new Date();
const availability = today >= availabilityDate ? 'immédiatement' : 'octobre 2026';
---

<section
    id="home"
    class="px-4 md:px-8 pt-36 pb-16 md:pt-44 md:pb-24"
>
    <div class="max-w-content mx-auto">
        <!-- Disponibilité -->
        <p class="font-mono text-sm text-ink-500 dark:text-ink-300 mb-8">
            <span class="text-green-500 dark:text-green-400" aria-hidden="true">●</span>
            Disponible {availability} · Île-de-France
        </p>

        <!-- Titre -->
        <h1
            class="font-display text-5xl md:text-7xl leading-[1.08] text-ink-900 dark:text-ink-50 max-w-5xl mb-8"
        >
            Baptiste TABAR LABONNE<br>
            <em class="text-accent-600 dark:text-accent-300">Développeur Full-Stack</em>
            <!-- du schéma de base de données au pixel. -->
        </h1>

        <!-- Présentation -->
        <p class="text-lg md:text-xl text-ink-500 dark:text-ink-300 leading-relaxed max-w-2xl mb-10">
            Après trois ans d'alternance au Conseil Départemental du Val-de-Marne,
            diplômé Architecte Web à la Digital School of Paris, je conçois des
            applications robustes du premier schéma de base de données jusqu'à la mise
            en production.
        </p>

        <!-- CTA -->
        <div class="flex flex-wrap items-center gap-4 mb-16">
            <a
                href="#projects"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-ink-900 text-paper dark:bg-ink-50 dark:text-night-bg font-medium hover:bg-ink-700 dark:hover:bg-ink-200 transition-colors"
            >
                Voir mes projets
                <Icon name="heroicons:arrow-down" class="w-4 h-4" aria-hidden="true" />
            </a>
            <a
                href="#contact"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-ink-300 dark:border-night-border text-ink-700 dark:text-ink-100 font-medium hover:border-ink-500 dark:hover:border-ink-400 transition-colors"
            >
                Me contacter
            </a>
        </div>

        <!-- Preuves chiffrées, en ligne sobre -->
        <dl class="flex flex-wrap gap-x-10 gap-y-4 pt-8 border-t border-ink-200 dark:border-night-border max-w-2xl">
            <div class="flex flex-col-reverse">
                <dt class="text-sm text-ink-500 dark:text-ink-300">années d'alternance</dt>
                <dd class="font-mono text-2xl text-ink-900 dark:text-ink-50">3</dd>
            </div>
            <div class="flex flex-col-reverse">
                <dt class="text-sm text-ink-500 dark:text-ink-300">projets en production</dt>
                <dd class="font-mono text-2xl text-ink-900 dark:text-ink-50">4</dd>
            </div>
            <div class="flex flex-col-reverse">
                <dt class="text-sm text-ink-500 dark:text-ink-300">stack principale</dt>
                <dd class="font-mono text-2xl text-ink-900 dark:text-ink-50">TS · PHP</dd>
            </div>
            <div class="flex flex-col-reverse">
                <dt class="text-sm text-ink-500 dark:text-ink-300">niveau d'études</dt>
                <dd class="font-mono text-2xl text-ink-900 dark:text-ink-50">BAC+5</dd>
            </div>
        </dl>
    </div>
</section>

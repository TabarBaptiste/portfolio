---
import { Icon } from "astro-icon/components";
---

<section
    id="home"
    class="px-4 md:px-8 pt-36 pb-16 md:pt-44 md:pb-24"
>
    <div class="max-w-content mx-auto">
        <!-- Disponibilité -->
        <p
            class="inline-flex items-center gap-2 rounded-full border border-accent-200 dark:border-accent-800 bg-accent-50 dark:bg-accent-900/40 px-3.5 py-1.5 text-sm text-accent-700 dark:text-accent-200 mb-8"
        >
            <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            Disponible dès octobre 2026, en Île-de-France et en Martinique
        </p>

        <!-- Titre -->
        <h1
            class="font-display text-5xl md:text-7xl leading-[1.08] text-ink-900 dark:text-ink-50 max-w-4xl mb-8"
        >
            Je conçois des applications web
            <em class="text-accent-600 dark:text-accent-300">complètes</em>,
            du schéma de base de données au pixel.
        </h1>

        <!-- Présentation -->
        <p class="text-lg md:text-xl text-ink-500 dark:text-ink-300 leading-relaxed max-w-2xl mb-10">
            Je m'appelle Baptiste Tabar Labonne. Après trois ans d'alternance au
            Conseil Départemental du Val-de-Marne, j'ai mis en production une
            plateforme de réservation pour une vraie cliente et publié une
            extension sur le Marketplace VSCode.
        </p>

        <!-- CTA -->
        <div class="flex flex-wrap items-center gap-4 mb-16">
            <a
                href="#projects"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-ink-900 text-paper dark:bg-ink-50 dark:text-night-bg font-medium hover:bg-ink-700 dark:hover:bg-ink-200 transition-colors"
            >
                Voir mes projets
                <Icon name="heroicons:arrow-down" class="w-4 h-4" aria-hidden="true" />
            </a>
            <a
                href="#contact"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-ink-300 dark:border-night-border text-ink-700 dark:text-ink-100 font-medium hover:border-ink-500 dark:hover:border-ink-400 transition-colors"
            >
                Me contacter
            </a>
        </div>

        <!-- Preuves chiffrées, en ligne sobre plutôt qu'en cartes -->
        <dl class="flex flex-wrap gap-x-10 gap-y-4 pt-8 border-t border-ink-200 dark:border-night-border max-w-2xl">
            <div class="flex flex-col-reverse">
                <dt class="text-sm text-ink-500 dark:text-ink-300">années d'alternance</dt>
                <dd class="font-mono text-2xl text-ink-900 dark:text-ink-50">3</dd>
            </div>
            <div class="flex flex-col-reverse">
                <dt class="text-sm text-ink-500 dark:text-ink-300">projets en production</dt>
                <dd class="font-mono text-2xl text-ink-900 dark:text-ink-50">4</dd>
            </div>
            <div class="flex flex-col-reverse">
                <dt class="text-sm text-ink-500 dark:text-ink-300">stack principale</dt>
                <dd class="font-mono text-2xl text-ink-900 dark:text-ink-50">TS · Next · Nest</dd>
            </div>
        </dl>
    </div>
</section>

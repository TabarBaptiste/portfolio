---
import { Icon } from "astro-icon/components";
---

<section
    id="home"
    class="px-4 md:px-8 pt-36 pb-16 md:pt-44 md:pb-24"
>
    <div class="max-w-content mx-auto">
        <!-- Disponibilité -->
        <p
            class="inline-flex items-center gap-2 rounded-full border border-accent-200 dark:border-accent-800 bg-accent-50 dark:bg-accent-900/40 px-3.5 py-1.5 text-sm text-accent-700 dark:text-accent-200 mb-8"
        >
            <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-500"></span>
            </span>
            Disponible dès octobre 2026 — Île-de-France & Martinique
        </p>

        <!-- Titre -->
        <h1
            class="font-display text-5xl md:text-7xl leading-[1.08] text-ink-900 dark:text-ink-50 max-w-4xl mb-8"
        >
            Je conçois des applications web
            <em class="text-accent-600 dark:text-accent-300">complètes</em> —
            du schéma de base de données au pixel.
        </h1>

        <!-- Présentation -->
        <p class="text-lg md:text-xl text-ink-500 dark:text-ink-300 leading-relaxed max-w-2xl mb-10">
            Baptiste Tabar Labonne, développeur full-stack. Trois ans d'alternance
            au Conseil Départemental du Val-de-Marne, une plateforme de réservation
            en production avec de vrais clients, et une extension publiée sur le
            Marketplace VSCode.
        </p>

        <!-- CTA -->
        <div class="flex flex-wrap items-center gap-4 mb-16">
            <a
                href="#projects"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-ink-900 text-paper dark:bg-ink-50 dark:text-night-bg font-medium hover:bg-ink-700 dark:hover:bg-ink-200 transition-colors"
            >
                Voir mes études de cas
                <Icon name="heroicons:arrow-down" class="w-4 h-4" aria-hidden="true" />
            </a>
            <a
                href="#contact"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-ink-300 dark:border-night-border text-ink-700 dark:text-ink-100 font-medium hover:border-ink-500 dark:hover:border-ink-400 transition-colors"
            >
                Me contacter
            </a>
        </div>

        <!-- Preuves chiffrées -->
        <dl class="grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-2xl">
            <div class="card px-5 py-4">
                <dt class="text-sm text-ink-400 dark:text-ink-300 mb-1">Années d'alternance</dt>
                <dd class="text-2xl font-medium text-ink-900 dark:text-ink-50">3</dd>
            </div>
            <div class="card px-5 py-4">
                <dt class="text-sm text-ink-400 dark:text-ink-300 mb-1">Projets en production</dt>
                <dd class="text-2xl font-medium text-ink-900 dark:text-ink-50">4</dd>
            </div>
            <div class="card px-5 py-4">
                <dt class="text-sm text-ink-400 dark:text-ink-300 mb-1">Stack principale</dt>
                <dd class="font-mono text-sm mt-2 text-ink-900 dark:text-ink-50">TS · Next · Nest</dd>
            </div>
        </dl>
    </div>
</section>

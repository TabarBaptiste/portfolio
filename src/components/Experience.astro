---
import Section from './ui/Section.astro';
import Button from './ui/Button.astro';
import { Icon } from 'astro-icon/components';

// Dès le 01/10/2026, on affiche "2026" à la place de "présent"
const endOfContract = new Date('2026-10-01');
const today = new Date();
const endYear = today >= endOfContract ? '2026' : 'présent';

const experiences = [
  {
    title: 'Mastère Architecte Web',
    company: 'Digital School of Paris - Institut F2I',
    period: `2024 - ${endYear}`,
    year: 2026,
    description: "Formation d'expertise en alternance orientée architecture web, développement full-stack et pilotage de projets digitaux.",
    type: 'education'
  },
  {
    title: 'Développeur Full-Stack en alternance',
    company: 'Conseil Départemental du Val-de-Marne',
    period: `2023 - ${endYear}`,
    year: 2023.5,
    description: "Refonte complète d'applications web, optimisation de bases de données, maintenance de solutions existantes. Conception d'une extension VSCode publiée sur le Marketplace pour améliorer la productivité de l'équipe.",
    type: 'work'
  },
  {
    title: "Licence Professionnelle - Applications Web (DAW2I)",
    company: "Université d'Evry Val d'Essonne - Paris Saclay",
    period: '2023 - 2024',
    year: 2023.2,
    description: "Développement avancé d'applications web et mobiles : modélisation de données, conception d'interfaces, intégration de services web.",
    type: 'education',
    link: {
      label: 'Voir ma soutenance',
      url: 'https://www.canva.com/design/DAGQdmJ6wv4/7Lu6Ywv06X51AH2pgMDwWg/view?utm_content=DAGQdmJ6wv4&utm_campaign=designshare&utm_medium=link2&utm_source=uniquelinks&utlId=haa0fe0e684'
    }
  },
  {
    title: 'Développeur Web - Stage',
    company: 'RJ Web',
    period: '2023',
    year: 2023,
    description: "Développement d'une plateforme communautaire : inscriptions aux évènements du quartier, newsletter automatisée, espace administrateur.",
    type: 'work'
  },
  {
    title: 'Développeur Web - Stage',
    company: 'Crédit Agricole',
    period: '2022',
    year: 2022,
    description: "Pôle Achat Technologie Service : interfaces web, gestion de bases de données et scripts d'automatisation des processus internes.",
    type: 'work'
  },
  {
    title: 'BTS SIO - Option SLAM',
    company: 'Lycée Léonard de Vinci, Melun',
    period: '2021 - 2023',
    year: 2022.5,
    description: 'Solutions Logicielles et Applications Métiers : programmation, gestion de projet, sécurité informatique.',
    type: 'education'
  }
].sort((a, b) => b.year - a.year);
---

<Section
  id="experience"
  title="Parcours"
  subtitle="Du BTS au Mastère Architecte Web, avec trois ans d'alternance au Conseil Départemental du Val-de-Marne."
>
  <div class="max-w-3xl">
    {experiences.map((exp) => (
      <div class="reveal grid grid-cols-[7rem_1fr] md:grid-cols-[9rem_1fr] gap-4 md:gap-8 py-6 border-b border-ink-200 dark:border-night-border last:border-b-0">
        <p class="font-mono text-sm text-ink-400 dark:text-ink-300 pt-0.5">
          {exp.period}
        </p>
        <div>
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <h3 class="font-semibold text-ink-900 dark:text-ink-50">
              {exp.title}
            </h3>
            <span class={`font-mono text-[11px] uppercase tracking-wider px-2 py-0.5 rounded ${
              exp.type === 'work'
                ? 'bg-accent-50 text-accent-600 dark:bg-accent-900 dark:text-accent-200'
                : 'bg-ink-100 text-ink-500 dark:bg-night-border dark:text-ink-300'
            }`}>
              {exp.type === 'work' ? 'Expérience' : 'Formation'}
            </span>
          </div>
          <p class="text-sm text-accent-600 dark:text-accent-300 mb-2">{exp.company}</p>
          <p class="text-sm text-ink-500 dark:text-ink-300 leading-relaxed">
            {exp.description}
          </p>
          {exp.link && (
            <a
              href={exp.link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline inline-flex items-center gap-1 text-sm mt-2"
            >
              {exp.link.label}
              <Icon name="heroicons:arrow-top-right-on-square" class="w-3.5 h-3.5" aria-hidden="true" />
            </a>
          )}
        </div>
      </div>
    ))}
  </div>

  <!-- CV -->
  <div class="mt-10 reveal">
    <Button href="Curriculum_Vitae_TABAR_LABONNE_Baptiste.pdf" variant="outline">
      <Icon name="heroicons:document-arrow-down" class="w-5 h-5 mr-2" aria-hidden="true" />
      Télécharger mon CV
    </Button>
  </div>
</Section>

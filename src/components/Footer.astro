---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-ink-200 dark:border-night-border mt-8">
    <div class="max-w-content mx-auto px-4 md:px-8 py-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-3 font-mono text-xs text-ink-500 dark:text-ink-300">
            <p>© {currentYear} Baptiste TABAR LABONNE</p>
            <p>
                conçu et développé par mes soins avec
                <a
                    href="https://astro.build"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-accent-600 dark:hover:text-accent-300 transition-colors"
                >Astro</a>
                 ·
                <a
                    href="https://tailwindcss.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-accent-600 dark:hover:text-accent-300 transition-colors"
                >Tailwind</a>
                 ·
                <a
                    href="https://github.com/TabarBaptiste/portfolio"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-accent-600 dark:hover:text-accent-300 transition-colors"
                >code source</a>
            </p>
        </div>
    </div>
</footer>

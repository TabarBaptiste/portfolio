---
import Section from "./ui/Section.astro";

const principles = [
    {
        title: "Refondre sans tout casser",
        description:
            "Trois ans sur des applications legacy au Conseil Départemental du Val-de-Marne : moderniser un code qui tourne depuis des années demande de la méthode, pas de la table rase.",
    },
    {
        title: "Du code qui se relit dans six mois",
        description:
            "Je privilégie les architectures qu'on peut faire évoluer sans souffrir : séparation claire des responsabilités, typage strict, conventions cohérentes.",
    },
    {
        title: "Livrer, monitorer, corriger",
        description:
            "Un projet n'est pas fini au merge : CI/CD systématique, monitoring Sentry en production, et correction rapide quand un utilisateur rencontre un problème.",
    },
    {
        title: "Full-stack pour de vrai",
        description:
            "Du schéma de base de données à l'interface, en passant par l'API et le déploiement. J'aime quand le frontend et le backend se parlent bien.",
    },
];
---

<Section
    id="about"
    title="Comment je travaille"
    subtitle="Développeur full-stack en fin de Mastère Architecte Web à la Digital School of Paris."
>
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-10 max-w-4xl">
        {principles.map((principle, index) => (
            <div class="reveal" style={`transition-delay: ${index * 0.06}s`}>
                <p class="font-mono text-xs text-accent-600 dark:text-accent-300 mb-2">
                    0{index + 1}
                </p>
                <h3 class="text-lg font-semibold text-ink-900 dark:text-ink-50 mb-2">
                    {principle.title}
                </h3>
                <p class="text-ink-500 dark:text-ink-300 leading-relaxed text-sm">
                    {principle.description}
                </p>
            </div>
        ))}
    </div>
</Section>

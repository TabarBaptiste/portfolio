---
import Section from "./ui/Section.astro";

const principles = [
    {
        title: "Refondre sans tout casser",
        description:
            "Trois ans sur des applications legacy au Conseil Départemental du Val-de-Marne. J'ai appris à moderniser du code qui tourne depuis des années sans interrompre le service pour les agents qui l'utilisent.",
    },
    {
        title: "Du code qui se relit dans six mois",
        description:
            "Je préfère un code simple et bien typé à une architecture impressionnante que personne ne comprend. Ce qui compte pour moi : que la personne qui passe après moi s'y retrouve.",
    },
    {
        title: "Livrer, surveiller, corriger",
        description:
            "Un projet ne s'arrête pas au merge. Je mets en place la CI/CD, je surveille la production avec Sentry, et quand un utilisateur rencontre un bug, je le corrige vite.",
    },
    {
        title: "Full-stack pour de vrai",
        description:
            "Base de données, API, interface, déploiement : je m'occupe de toute la chaîne. Et j'aime que le front et le back se parlent bien.",
    },
];
---

<Section
    id="about"
    title="Comment je travaille"
    subtitle="Développeur full-stack en fin de Mastère Architecte Web à la Digital School of Paris."
>
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-10 max-w-4xl">
        {principles.map((principle, index) => (
            <div class="reveal" style={`transition-delay: ${index * 0.06}s`}>
                <p class="font-mono text-xs text-accent-600 dark:text-accent-300 mb-2">
                    0{index + 1}
                </p>
                <h3 class="text-lg font-semibold text-ink-900 dark:text-ink-50 mb-2">
                    {principle.title}
                </h3>
                <p class="text-ink-500 dark:text-ink-300 leading-relaxed text-sm">
                    {principle.description}
                </p>
            </div>
        ))}
    </div>
</Section>

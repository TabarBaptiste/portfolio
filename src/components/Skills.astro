        </svg>`,
        skills: [
            "HTML5",
            "CSS3",
            "JavaScript",
            "TypeScript",
            "Angular",
            "Next.js",
            "Vue.js",
            "Astro",
            "React",
            "ExtJS",
            "Responsive Design",
            "Accessibilité Web",

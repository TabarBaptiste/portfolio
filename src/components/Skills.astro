---
import Section from "./ui/Section.astro";

const tiers = [
    {
        label: "Au quotidien",
        description: "Mon socle de travail, celui de mes projets en production.",
        highlight: true,
        skills: [
            "TypeScript",
            "Next.js / React",
            "NestJS / Node.js",
            "PostgreSQL",
            "Prisma",
            "Tailwind CSS",
            "Git / GitHub",
        ],
    },
    {
        label: "Opérationnel",
        description: "Utilisé régulièrement en entreprise ou sur des projets livrés.",
        highlight: false,
        skills: [
            "PHP / Symfony",
            "Astro",
            "Docker",
            "GitHub Actions / Jenkins",
            "MySQL",
            "Supabase / Firebase",
            "Flutter / Dart",
            "Sentry",
            "Stripe",
            "SEO",
        ],
    },
    {
        label: "Déjà pratiqué",
        description: "Abordé en formation ou sur des projets ponctuels.",
        highlight: false,
        skills: [
            "Angular",
            "Vue.js",
            "ExtJS",
            "Express",
            "SonarQube",
            "Vercel / Netlify / Render / Railway",
            "UML",
            "Scrum / Kanban",
            "Figma",
        ],
    },
];
---

<Section
    id="skills"
    title="Compétences"
    subtitle="Classées honnêtement : ce que je pratique tous les jours d'abord."
>
    <div class="space-y-6 max-w-4xl">
        {tiers.map((tier, index) => (
            <div class="reveal card p-6 md:p-8" style={`transition-delay: ${index * 0.06}s`}>
                <div class="md:flex md:items-start md:gap-10">
                    <div class="md:w-56 flex-shrink-0 mb-4 md:mb-0">
                        <h3 class={`font-semibold mb-1 ${tier.highlight ? "text-accent-600 dark:text-accent-300" : "text-ink-900 dark:text-ink-50"}`}>
                            {tier.label}
                        </h3>
                        <p class="text-sm text-ink-400 dark:text-ink-300 leading-relaxed">
                            {tier.description}
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {tier.skills.map((skill) => (
                            <span class={`font-mono text-sm px-3 py-1.5 rounded-lg border ${
                                tier.highlight
                                    ? "bg-accent-50 text-accent-700 border-accent-200 dark:bg-accent-900/40 dark:text-accent-200 dark:border-accent-800"
                                    : "bg-ink-50 text-ink-600 border-ink-200 dark:bg-night-bg dark:text-ink-200 dark:border-night-border"
                            }`}>
                                {skill}
                            </span>
                        ))}
                    </div>
                </div>
            </div>
        ))}
    </div>
</Section>

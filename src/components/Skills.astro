    {
        title: "Gestion de projet",
        icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
        </svg>`,
        skills: [
            "Agile / Scrum",
            "Kanban",
            "Notion",
            "GitHub Projects",
            "Diagrammes Gantt",
            "Modélisation UML",
        ],
    },
];

/*
  OPTION : afficher des niveaux texte par compétence
  Pour activer, passer les skills en tableau d'objets { name: string; level: 'Avancé' | 'Intermédiaire' | 'Notions' }
  et utiliser ce template à la place du badge simple ci-dessous :

  <span class="px-3 py-1.5 rounded-lg bg-dark-800/50 text-sm border border-dark-700
               flex items-center justify-between gap-2">
    <span class="text-dark-200">{skill.name}</span>
    <span class={`text-xs px-2 py-0.5 rounded whitespace-nowrap ${
      skill.level === 'Avancé' ? 'text-green-400 bg-green-400/10' :
      skill.level === 'Intermédiaire' ? 'text-yellow-400 bg-yellow-400/10' :
      'text-dark-400 bg-dark-700/50'
    }`}>{skill.level}</span>
  </span>
*/
---

<Section
    id="skills"
    title="Compétences"
    subtitle="Technologies et outils que je maîtrise"
>
    <div class="grid md:grid-cols-2 gap-6">
        {skillCategories.map((category, catIndex) => (
            <div
                class="reveal h-full"
                style={`animation-delay: ${catIndex * 0.08}s`}
            >
                <Card hover={false} className="h-full flex flex-col">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white flex-shrink-0">
                            <Fragment set:html={category.icon} />
                        </div>
                        <h3 class="text-xl font-bold text-dark-100">
                            {category.title}
                        </h3>
                    </div>

                    <div class="flex flex-wrap gap-2">
                        {category.skills.map((skill) => (
                            <span class="skill-badge">
                                {skill}
                            </span>
                        ))}
                    </div>
                </Card>
            </div>
        ))}
    </div>
</Section>

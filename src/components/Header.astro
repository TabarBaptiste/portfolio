---
import { Icon } from "astro-icon/components";

const navItems = [
    { name: "Projets", href: "/#projects" },
    { name: "Parcours", href: "/#experience" },
    { name: "Compétences", href: "/#skills" },
    { name: "Contact", href: "/#contact" },
];
---

<header
    id="header"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
    <nav class="max-w-content mx-auto px-4 md:px-8 py-4">
        <div class="flex items-center justify-between">
            <!-- Logo -->
            <a
                href="/"
                class="font-mono text-sm font-medium text-ink-800 dark:text-ink-100 hover:text-accent-600 dark:hover:text-accent-300 transition-colors"
            >
                baptiste.tabar-labonne
            </a>

            <!-- Navigation desktop -->
            <ul class="hidden md:flex items-center gap-8">
                {
                    navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class="text-sm text-ink-500 dark:text-ink-300 hover:text-ink-900 dark:hover:text-ink-50 transition-colors"
                            >
                                {item.name}
                            </a>
                        </li>
                    ))
                }
            </ul>

            <div class="flex items-center gap-2">
                <!-- Toggle thème -->
                <button
                    id="theme-toggle"
                    class="p-2 rounded-lg border border-transparent hover:border-ink-200 dark:hover:border-night-border text-ink-500 dark:text-ink-300 transition-colors"
                    aria-label="Basculer le thème clair/sombre"
                >
                    <Icon
                        name="heroicons:moon"
                        id="theme-icon-moon"
                        class="w-4 h-4"
                        aria-hidden="true"
                    />
                    <Icon
                        name="heroicons:sun"
                        id="theme-icon-sun"
                        class="w-4 h-4 hidden"
                        aria-hidden="true"
                    />
                </button>

                <!-- Menu mobile -->
                <button
                    id="mobile-menu-button"
                    class="md:hidden p-2 text-ink-700 dark:text-ink-100"
                    aria-label="Menu"
                >
                    <Icon id="menu-icon-open" name="heroicons:bars-3" class="w-5 h-5" aria-hidden="true" />
                    <Icon id="menu-icon-close" name="heroicons:x-mark" class="w-5 h-5 hidden" aria-hidden="true" />
                </button>
            </div>
        </div>

        <!-- Menu mobile -->
        <div
            id="mobile-menu"
            class="md:hidden hidden mt-3 card p-3 shadow-lg"
        >
            <ul class="space-y-1">
                {
                    navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class="block py-2 px-3 rounded-lg text-ink-600 dark:text-ink-200 hover:bg-ink-50 dark:hover:bg-night-border transition-colors"
                            >
                                {item.name}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>
    </nav>
</header>

<script>
    // Fond du header au scroll
    const header = document.getElementById("header");
    const onScroll = () => {
        if (window.scrollY > 40) {
            header?.classList.add("header-scrolled");
        } else {
            header?.classList.remove("header-scrolled");
        }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Menu mobile
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIconOpen = document.getElementById("menu-icon-open");
    const menuIconClose = document.getElementById("menu-icon-close");

    mobileMenuButton?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
        menuIconOpen?.classList.toggle("hidden");
        menuIconClose?.classList.toggle("hidden");
    });

    mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
            mobileMenu.classList.add("hidden");
            menuIconOpen?.classList.remove("hidden");
            menuIconClose?.classList.add("hidden");
        });
    });

    // Thème : les icônes reflètent l'état, l'init est faite dans Layout
    const sunIcon = document.getElementById("theme-icon-sun");
    const moonIcon = document.getElementById("theme-icon-moon");

    const updateThemeIcons = () => {
        const isDark = document.documentElement.classList.contains("dark");
        sunIcon?.classList.toggle("hidden", !isDark);
        moonIcon?.classList.toggle("hidden", isDark);
    };
    updateThemeIcons();

    document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const html = document.documentElement;
        const isDark = html.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        updateThemeIcons();
    });
</script>

<style>
    .header-scrolled {
        @apply bg-paper/85 dark:bg-night-bg/85 border-b border-ink-200/60 dark:border-night-border;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }
</style>

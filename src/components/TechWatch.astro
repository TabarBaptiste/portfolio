---
import Section from "./ui/Section.astro";
import Card from "./ui/Card.astro";
import { Icon } from "astro-icon/components";

const techItems = [
    {
        title: "GitHub Copilot",
        icon: "simple-icons:githubcopilot",
        description: "Assistant IA intégré directement dans l'éditeur de code, GitHub Copilot transforme la façon dont les développeurs écrivent du code. Il suggère des lignes complètes, des fonctions entières et peut même générer des tests unitaires automatiquement.",
        features: [
            "Complétion de code intelligente en temps réel",
            "Mode agent pour des tâches complexes et autonomes",
            "Intégration dans VS Code, JetBrains, Neovim et d'autres IDE",
            "Support de multiples LLMs (GPT-5, Claude Sonnet 4.5, Gemini, Grok Code)",
            "Coding agent capable d'ouvrir des pull requests autonomes"
        ],
        useCases: "Développement d'applications web, refactoring de code legacy, génération de tests, documentation automatique",
        link: "https://github.com/features/copilot",
        gradient: "from-purple-500 to-blue-600"
    },
    {
        title: "Model Context Protocol (MCP)",
        icon: "heroicons:bolt",
        description: "MCP est un standard open-source qui permet aux applications IA de se connecter à des systèmes externes. Comme un port USB-C pour l'IA, il standardise la connexion entre les modèles d'IA et vos données, outils et workflows.",
        features: [
            "Connexion standardisée aux sources de données externes",
            "Intégration d'outils et de services tiers",
            "Architecture modulaire et extensible",
            "Compatible avec Claude, ChatGPT et autres assistants IA",
            "Écosystème de serveurs MCP prêts à l'emploi"
        ],
        useCases: "Création d'agents personnalisés, intégration d'IA avec des bases de données, connexion à des APIs métier, workflows automatisés",
        link: "https://modelcontextprotocol.io/",
        gradient: "from-green-500 to-teal-600"
    },
    {
        title: "Claude Code & Computer Use",
        icon: "heroicons:computer-desktop",
        description: "Claude Sonnet 4.5 introduit une capacité révolutionnaire : utiliser un ordinateur comme le ferait un humain. Il peut voir l'écran, déplacer le curseur, cliquer et taper, ouvrant la voie à l'automatisation de tâches complexes.",
        features: [
            "Meilleur modèle pour le coding avec 49% sur SWE-bench",
            "Capacité 'Computer Use' pour contrôler des interfaces",
            "Navigation autonome dans des applications web ou desktop",
            "Automatisation de workflows multi-étapes",
            "Intégration avec VS Code via les extensions MCP"
        ],
        useCases: "Tests d'applications automatisés, remplissage de formulaires complexes, création et validation de code, recherche et analyse de données",
        link: "https://www.anthropic.com/news/3-5-models-and-computer-use",
        gradient: "from-orange-500 to-red-600"
    }
];
---

<Section
    id="tech-watch"
    title="Veille Technologique"
    subtitle="Intelligence Artificielle et Développement"
    className="bg-dark-800/30"
>
    <div class="mb-12 text-center reveal">
        <p class="text-dark-300 text-lg max-w-3xl mx-auto leading-relaxed">
            Dans le domaine du développement web, l'intelligence artificielle révolutionne nos méthodes de travail. 
            Voici les technologies IA que j'utilise et surveille activement pour optimiser ma productivité et la qualité de mes projets.
        </p>
    </div>

    <div class="space-y-12">
        {techItems.map((item, index) => (
            <div class="reveal" style={`animation-delay: ${index * 0.2}s`}>
                <Card className="overflow-hidden">
                    <div class="grid md:grid-cols-12 gap-6">
                        <!-- Icône et titre -->
                        <div class="md:col-span-3 flex flex-col items-center justify-center text-center">
                            <div class={`w-20 h-20 rounded-2xl bg-gradient-to-br ${item.gradient} flex items-center justify-center mb-4 shadow-lg`}>
                                <Icon name={item.icon} class="w-12 h-12 text-white" aria-hidden="true" />
                            </div>
                            <h3 class="text-xl font-bold text-dark-100 mb-2">
                                {item.title}
                            </h3>
                            <a 
                                href={item.link}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-primary-400 hover:text-primary-300 transition-colors inline-flex items-center gap-1"
                            >
                                En savoir plus
                                <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4" aria-hidden="true" />
                            </a>
                        </div>

                        <!-- Contenu -->
                        <div class="md:col-span-9 space-y-4">
                            <p class="text-dark-300 leading-relaxed">
                                {item.description}
                            </p>

                            <!-- Fonctionnalités -->
                            <div>
                                <h4 class="text-sm font-semibold text-primary-400 mb-2">Fonctionnalités clés :</h4>
                                <ul class="grid md:grid-cols-2 gap-2">
                                    {item.features.map((feature) => (
                                        <li class="flex items-start gap-2 text-dark-300 text-sm">
                                            <Icon name="heroicons:check" class="w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" aria-hidden="true" />
                                            <span>{feature}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>

                            <!-- Cas d'usage -->
                            <div class="pt-2 border-t border-dark-700">
                                <p class="text-sm text-dark-300">
                                    <span class="font-semibold text-dark-200">Cas d'usage :</span> {item.useCases}
                                </p>
                            </div>
                        </div>
                    </div>
                </Card>
            </div>
        ))}
    </div>

    <!-- Note personnelle -->
    <div class="mt-12 reveal">
        <Card className="border-l-4 border-primary-500">
            <div class="flex items-start gap-4">
                <div class="flex-shrink-0">
                    <div class="w-12 h-12 rounded-xl bg-primary-500/10 flex items-center justify-center">
                        <Icon name="heroicons:information-circle" class="w-6 h-6 text-primary-400" aria-hidden="true" />
                    </div>
                </div>
                <div>
                    <h4 class="text-lg font-bold text-dark-100 mb-2">Mon approche de l'IA</h4>
                    <p class="text-dark-300 leading-relaxed">
                        J'utilise quotidiennement ces outils d'IA pour accélérer mon développement, notamment GitHub Copilot pour la complétion de code 
                        et Claude pour l'architecture et la résolution de problèmes complexes. Cette veille technologique me permet de rester à la pointe 
                        des innovations et d'intégrer rapidement les meilleures pratiques dans mes projets professionnels.
                    </p>
                </div>
            </div>
        </Card>
    </div>
</Section>

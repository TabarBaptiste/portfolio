---
interface Props {
    id?: string;
    title?: string;
    subtitle?: string;
    className?: string;
}

const { id, title, subtitle, className = "" } = Astro.props;
---

<section id={id} class={`py-16 md:py-24 px-4 md:px-8 ${className}`}>
    <div class="max-w-content mx-auto">
        {title && (
            <div class="mb-12 reveal">
                <h2 class="font-display text-4xl md:text-5xl text-ink-900 dark:text-ink-50 mb-3">
                    {title}
                </h2>
                {subtitle && (
                    <p class="text-ink-500 dark:text-ink-300 text-lg max-w-2xl">
                        {subtitle}
                    </p>
                )}
            </div>
        )}
        <slot />
    </div>
</section>

---
interface Props {
    className?: string;
    hover?: boolean;
}

const { className = "", hover = true } = Astro.props;
---

<div
    class={`
    glass rounded-2xl p-6 card-shine
    ${hover ? "transition-shadow duration-300 hover:shadow-xl hover:shadow-primary-500/10" : ""}
    ${className}
    `}
>
    <slot />
</div>

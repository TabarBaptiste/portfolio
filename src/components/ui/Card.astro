---
interface Props {
    className?: string;
    hover?: boolean;
}

const { className = "", hover = true } = Astro.props;
---

<div
    class={`
    card p-6
    ${hover ? "transition-colors duration-200 hover:border-ink-300 dark:hover:border-ink-600" : ""}
    ${className}
    `}
>
    <slot />
</div>

---
import Section from './ui/Section.astro';
import Card from './ui/Card.astro';
import { projects } from '../data/projects';
import { Icon } from 'astro-icon/components';

const categories = ['all', 'web', 'mobile'];
---

<Section
  id="projects"
  title="Mes projets"
  subtitle="Une sélection de mes réalisations récentes"
  className="bg-dark-800/30"
>
  <!-- Filtres -->
  <div class="flex flex-wrap justify-center gap-3 mb-10 reveal">
    {categories.map((category) => (
      <button
        class="filter-btn px-6 py-2 rounded-xl glass text-dark-300 hover:text-primary-400 transition-colors duration-300"
        data-filter={category}
      >
        {category === 'all' ? 'Tous' : category.charAt(0).toUpperCase() + category.slice(1)}
      </button>
    ))}
  </div>

  <!-- Grille de projets -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
    {projects.map((project) => (
      <div
        id={project.slug}
        class="reveal project-card relative cursor-pointer"
        data-category={project.category}
        data-href={`/projects/${project.slug}`}
      >
        <Card className="h-full flex flex-col overflow-hidden group" hover={false}>
          <!-- Image -->
          <div class="relative overflow-hidden rounded-xl mb-4 aspect-video">
            <img
              src={project.image}
              alt={`Capture d'écran du projet ${project.title}`}
              data-image={project.image}
              data-image-light={project.imageLight}
              class={project.image && project.image.includes('logo') ? 'w-full h-full object-contain p-6 bg-white' : 'w-full h-full object-cover md:transition-transform md:duration-500 md:group-hover:scale-110'}
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark-900 via-dark-900/50 to-transparent opacity-60"></div>

            <!-- Overlay avec liens (desktop uniquement via hover) -->
            <div class="absolute inset-0 flex items-center justify-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10">
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 rounded-full bg-primary-500 flex items-center justify-center hover:bg-primary-600 transition-colors shadow-lg"
                  aria-label={project.demoLabel || "Voir la démo"}
                  title={project.demoLabel || "Voir la démo"}
                  onclick="event.stopPropagation()"
                >
                  <Icon name="heroicons:arrow-top-right-on-square" class="w-6 h-6 text-white" aria-hidden="true" />
                </a>
              )}
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 rounded-full bg-dark-700 flex items-center justify-center hover:bg-dark-600 transition-colors shadow-lg"
                  aria-label="Voir le code source sur GitHub"
                  title="Voir le code sur GitHub"
                  onclick="event.stopPropagation()"
                >
                  <Icon name="simple-icons:github" class="w-6 h-6 text-white" aria-hidden="true" />
                </a>
              )}
            </div>
          </div>

          <!-- Contenu -->
          <div class="flex-1 flex flex-col">
            <h3 class="text-xl font-bold text-dark-100 mb-2 group-hover:text-primary-400 transition-colors">
              {project.title}
            </h3>
            <p class="text-dark-200 mb-4 flex-1 text-sm leading-relaxed">
              {project.description}
            </p>

            <!-- Technologies -->
            <div class="flex flex-wrap gap-2 mb-4">
              {project.technologies.map((tech) => (
                <span class="px-3 py-1 rounded-lg bg-dark-800/50 text-primary-400 text-xs border border-dark-700">
                  {tech}
                </span>
              ))}
            </div>

            <!-- CTA -->
            <a
              href={`/projects/${project.slug}`}
              class="inline-flex items-center justify-center px-4 py-2 rounded-xl bg-primary-500/10 text-primary-400 border border-primary-500/30 hover:bg-primary-500 hover:text-white transition-all duration-300 group/btn touch-manipulation"
              aria-label={`Voir le projet ${project.title}`}
            >
              <span>Voir le projet</span>
              <Icon name="heroicons:chevron-right" class="w-4 h-4 ml-2 transition-transform group-hover/btn:translate-x-1" aria-hidden="true" />
            </a>
          </div>
        </Card>
      </div>
    ))}
  </div>

  <div id="no-projects" class="hidden text-center py-12">
    <p class="text-dark-400 text-lg">Aucun projet trouvé dans cette catégorie</p>
  </div>
</Section>

<script>
  // Filtrage des projets
  const filterButtons = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll<HTMLElement>('.project-card');
  const noProjectsMessage = document.getElementById('no-projects');

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const filter = button.getAttribute('data-filter');
      const isDark = document.documentElement.classList.contains('dark');
      const activeTextColor = isDark ? 'text-white' : 'text-primary-600';

      filterButtons.forEach(btn => {
        btn.classList.remove('bg-primary-500', 'text-white', 'text-primary-600');
        btn.classList.add('text-dark-300');
      });
      button.classList.add('bg-primary-500', activeTextColor);
      button.classList.remove('text-dark-300');

      let visibleCount = 0;
      projectCards.forEach((card) => {
        const category = card.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          card.style.display = 'block';
          card.style.animationDelay = `${visibleCount * 0.1}s`;
          card.classList.remove('active');
          setTimeout(() => card.classList.add('active'), 10);
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      noProjectsMessage?.classList.toggle('hidden', visibleCount > 0);
    });
  });

  // Activer le filtre "Tous" par défaut
  const allButton = document.querySelector('[data-filter="all"]');
  const isDark = document.documentElement.classList.contains('dark');
  const activeTextColor = isDark ? 'text-white' : 'text-primary-600';
  allButton?.classList.add('bg-primary-500', activeTextColor);
  allButton?.classList.remove('text-dark-300');

  // Rendre toute la carte cliquable (#23 - fix hit zone)
  projectCards.forEach(card => {
    card.addEventListener('click', (e) => {
      const target = e.target as Element;
      if (target.closest('a')) return;
      const href = card.getAttribute('data-href');
      if (href) window.location.href = href;
    });
  });

  // Mise à jour des images selon le thème
  const updateProjectImages = () => {
    const isDark = document.documentElement.classList.contains('dark');
    const projectImages = document.querySelectorAll('img[data-image][data-image-light]');
    projectImages.forEach(img => {
      const imageElement = img as HTMLImageElement;
      const darkImage = imageElement.getAttribute('data-image');
      const lightImage = imageElement.getAttribute('data-image-light');
      if (lightImage) {
        imageElement.src = isDark ? darkImage || '' : lightImage;
      }
    });
  };

  updateProjectImages();

  const themeObserver = new MutationObserver(() => updateProjectImages());
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class']
  });
</script>

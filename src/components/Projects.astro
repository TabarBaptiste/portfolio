---
import Section from "./ui/Section.astro";
import { projects } from "../data/projects";
import { Icon } from "astro-icon/components";

const bySlug = (slug: string) => projects.find((p) => p.slug === slug)!;

const alydousheure = bySlug("alydousheure-fullstack");
const daoGenerator = bySlug("dao-generator");
const fuel = bySlug("fuel");
const compactProjects = [bySlug("alydousheure"), bySlug("beroli"), bySlug("rjweb")];

// Nombre d'installations de l'extension VSCode, récupéré au build (fallback silencieux)
let marketplaceInstalls: number | null = null;
try {
    const res = await fetch(
        "https://marketplace.visualstudio.com/_apis/public/gallery/extensionquery",
        {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                Accept: "application/json;api-version=3.0-preview.1",
            },
            body: JSON.stringify({
                filters: [
                    {
                        criteria: [
                            {
                                filterType: 7,
                                value: "Baptiste-TABAR-LABONNE.php-dao-generator",
                            },
                        ],
                    },
                ],
                flags: 256,
            }),
            signal: AbortSignal.timeout(10_000),
        },
    );
    if (res.ok) {
        const data = await res.json();
        const stats = data.results?.[0]?.extensions?.[0]?.statistics;
        const installs = stats?.find(
            (s: { statisticName: string }) => s.statisticName === "install",
        )?.value;
        if (typeof installs === "number") marketplaceInstalls = Math.round(installs);
    }
} catch {
    // Pas de réseau au build : on n'affiche simplement pas le compteur
}
---

<Section
    id="projects"
    title="Projets"
    subtitle="Pour chaque projet, j'explique le besoin de départ, mes choix techniques et le résultat."
>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <!-- Projet phare : plateforme en production -->
        <a
            id={alydousheure.slug}
            href={`/projects/${alydousheure.slug}`}
            class="reveal scroll-mt-28 md:col-span-2 card p-0 overflow-hidden group hover:border-ink-300 dark:hover:border-ink-600 transition-colors"
        >
            <!-- TODO : remplacer par une vraie capture d'alydousheure.fr (ex. /projects/alydousheure/accueil.png, ~1600x760) -->
            <div class="px-8 py-12 border-b border-ink-200 dark:border-night-border bg-gradient-to-br from-accent-50 to-paper dark:from-accent-900/30 dark:to-night-card">
                <p class="font-display text-3xl md:text-4xl text-ink-900 dark:text-ink-50 mb-2">
                    Aly dous'heure
                </p>
                <p class="text-ink-500 dark:text-ink-300 text-sm max-w-md">
                    Réservation en ligne, paiement sécurisé et back-office
                    pour une masseuse professionnelle indépendante.
                </p>
            </div>

            <div class="p-6">
                <div class="flex flex-wrap items-center gap-3 mb-4">
                    <span class="status-badge">
                        <span class="w-1.5 h-1.5 rounded-full bg-green-500 dark:bg-green-400" aria-hidden="true"></span>
                        En production
                    </span>
                    <span class="tech-label">NestJS · Next.js · Prisma · Stripe Connect</span>
                </div>
                <h3 class="text-xl font-semibold text-ink-900 dark:text-ink-50 mb-2 group-hover:text-accent-600 dark:group-hover:text-accent-300 transition-colors">
                    Plateforme de réservation full-stack
                </h3>
                <p class="text-ink-500 dark:text-ink-300 text-sm leading-relaxed mb-4">
                    Développée en autonomie pour une cliente : réservation en temps réel,
                    paiement Stripe Connect, tableau de bord statistiques, CI/CD et
                    déploiement automatisé. La cliente gère aujourd'hui son activité seule.
                </p>
                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-600 dark:text-accent-300">
                    Voir le projet en détail
                    <Icon name="heroicons:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" aria-hidden="true" />
                </span>
            </div>
        </a>

        <!-- Extension VSCode publiée -->
        <a
            id={daoGenerator.slug}
            href={`/projects/${daoGenerator.slug}`}
            class="reveal scroll-mt-28 card p-6 flex flex-col group hover:border-ink-300 dark:hover:border-ink-600 transition-colors"
        >
            <div class="flex items-center justify-between mb-5">
                <Icon name="heroicons:puzzle-piece" class="w-8 h-8 text-accent-600 dark:text-accent-300" aria-hidden="true" />
                <span class="status-badge">Publié sur le Marketplace</span>
            </div>
            <h3 class="text-xl font-semibold text-ink-900 dark:text-ink-50 mb-2 group-hover:text-accent-600 dark:group-hover:text-accent-300 transition-colors">
                PHP DAO Generator
            </h3>
            <p class="text-ink-500 dark:text-ink-300 text-sm leading-relaxed mb-4 flex-1">
                Extension VSCode qui génère les fichiers DAO à partir des tables
                d'une base de données. Développée pour mon équipe au Conseil
                Départemental, avec CI/CD complet et monitoring Sentry.
            </p>
            {marketplaceInstalls !== null && (
                <p class="font-mono text-sm text-ink-700 dark:text-ink-100 mb-4">
                    <span class="text-2xl font-medium">{marketplaceInstalls.toLocaleString("fr-FR")}</span>
                    <span class="text-ink-500 dark:text-ink-300"> installations</span>
                </p>
            )}
            <div class="flex items-center justify-between">
                <span class="tech-label">TypeScript · Sentry · CI/CD</span>
                <Icon name="heroicons:arrow-right" class="w-4 h-4 text-accent-600 dark:text-accent-300 transition-transform group-hover:translate-x-1" aria-hidden="true" />
            </div>
        </a>

        <!-- Fuel : démo live avec capture réelle -->
        <a
            id={fuel.slug}
            href={`/projects/${fuel.slug}`}
            class="reveal scroll-mt-28 card p-0 overflow-hidden group hover:border-ink-300 dark:hover:border-ink-600 transition-colors"
        >
            <div class="aspect-video overflow-hidden border-b border-ink-200 dark:border-night-border">
                <img
                    src="/projects/fuel/tableau_bord.png"
                    alt="Tableau de bord de l'application Fuel"
                    class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                />
            </div>
            <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                    <span class="status-badge">Démo live</span>
                    <span class="tech-label">Next.js · Prisma</span>
                </div>
                <h3 class="text-lg font-semibold text-ink-900 dark:text-ink-50 mb-1 group-hover:text-accent-600 dark:group-hover:text-accent-300 transition-colors">
                    Fuel, suivi de consommation
                </h3>
                <p class="text-ink-500 dark:text-ink-300 text-sm leading-relaxed">
                    Suivi des pleins d'essence : statistiques, graphiques et
                    estimations de trajet calculées automatiquement.
                </p>
            </div>
        </a>

        <!-- Autres projets, en rangées compactes -->
        <div class="reveal md:col-span-2 card divide-y divide-ink-200 dark:divide-night-border">
            {compactProjects.map((project) => (
                <a
                    id={project.slug}
                    href={`/projects/${project.slug}`}
                    class="flex items-center gap-4 px-6 py-4 group scroll-mt-28 hover:bg-ink-50 dark:hover:bg-night-bg first:rounded-t-2xl last:rounded-b-2xl transition-colors"
                >
                    <div class="flex-1 min-w-0">
                        <h3 class="font-medium text-ink-900 dark:text-ink-50 group-hover:text-accent-600 dark:group-hover:text-accent-300 transition-colors truncate">
                            {project.title}
                        </h3>
                        <p class="tech-label mt-0.5 truncate">
                            {project.technologies.slice(0, 4).join(" · ")}
                        </p>
                    </div>
                    <Icon
                        name="heroicons:arrow-right"
                        class="w-4 h-4 flex-shrink-0 text-ink-500 dark:text-ink-300 transition-transform group-hover:translate-x-1"
                        aria-hidden="true"
                    />
                </a>
            ))}
        </div>
    </div>
</Section>
